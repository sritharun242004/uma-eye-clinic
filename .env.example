# Database (Vercel Postgres or any PostgreSQL)
# On Vercel: use Pooled connection for DATABASE_URL, Non-pooled for DIRECT_URL (migrations)
DATABASE_URL=
DIRECT_URL=

# NextAuth (required for admin login)
# On Vercel: set NEXTAUTH_URL to your production URL, e.g. https://your-app.vercel.app
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@umaeyeclinic.in
CLINIC_EMAIL=info@umaeyeclinic.in
